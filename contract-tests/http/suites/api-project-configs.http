@missingToken = invalid.jwt.token

# Prefer running regression through:
#   httpyac tests/bootstrap.http tests/fixtures.http tests/api-*.http --all
# so globals (tokens and fixture IDs) are present for generated cases.

### GET_/api/project-configs/{id}_happy
# @name GET__api_project_configs__id__happy
< {% await new Promise((resolve) => setTimeout(resolve, 7000)); %}
GET {{baseUrl}}/api/project-configs/{{fixtureProjectConfigId}}
Authorization: Bearer {{adminAccessToken}}



> {%
client.test("GET_/api/project-configs/{id}_happy -> [200]", function () {
  const expectedStatuses = [200];
  const responseBody = typeof response.body === 'string' ? response.body : JSON.stringify(response.body);
  client.assert(
    expectedStatuses.includes(response.status),
    'Unexpected status ' + response.status + '; expected [200]; body=' + (responseBody || '<empty>')
  );
});
%}

