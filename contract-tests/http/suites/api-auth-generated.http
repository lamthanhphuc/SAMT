### GEN_auth_register_password_mismatch
# @name GEN_auth_register_password_mismatch
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "email": "generated.user@samt.local",
  "password": "Str0ng@Pass!",
  "confirmPassword": "Mismatch@Pass1",
  "fullName": "Generated User",
  "role": "STUDENT"
}

> {%
client.test("GEN_auth_register_password_mismatch -> [400]", function () {
  const expectedStatuses = [400];
  const responseBody = typeof response.body === 'string' ? response.body : JSON.stringify(response.body);
  client.assert(
    expectedStatuses.includes(response.status),
    'Unexpected status ' + response.status + '; expected [400]; body=' + (responseBody || '<empty>')
  );
});
%}
