@baseUrl = http://localhost:9080
@unknownEmail = unknown.user@samt.local
@badPassword = WrongPass@123
@studentEmail = qa.student@samt.local
@studentPassword = Str0ng@Pass!

### GEN_auth_login_unknown_user
# @name GEN_auth_login_unknown_user
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "{{unknownEmail}}",
  "password": "{{badPassword}}"
}

> {%
client.test("GEN_auth_login_unknown_user -> [401]", function () {
  const expectedStatuses = [401];
  const responseBody = typeof response.body === 'string' ? response.body : JSON.stringify(response.body);
  client.assert(
    expectedStatuses.includes(response.status),
    'Unexpected status ' + response.status + '; expected [401]; body=' + (responseBody || '<empty>')
  );
});
%}

