@baseUrl = http://localhost:9080
@invalidUuid = not-a-uuid

### EDGE_auth_malformed_bearer_token
# @name EDGE_auth_malformed_bearer_token
GET {{baseUrl}}/api/users?page=0&size=1
Authorization: Bearer malformed.token

> {%
client.test("EDGE_auth_malformed_bearer_token -> [401]", function () {
  const expectedStatuses = [401];
  const responseBody = typeof response.body === 'string' ? response.body : JSON.stringify(response.body);
  client.assert(
    expectedStatuses.includes(response.status),
    'Unexpected status ' + response.status + '; expected [401]; body=' + (responseBody || '<empty>')
  );
  client.assert(!!responseBody, 'Expected non-empty unauthorized response body');
});
%}

### EDGE_users_list_schema_strict
# @name EDGE_users_list_schema_strict
GET {{baseUrl}}/api/users?page=0&size=1
Authorization: Bearer {{adminAccessToken}}

> {%
client.test("EDGE_users_list_schema_strict -> [200] + schema", function () {
  client.assert(response.status === 200, 'Unexpected status ' + response.status + '; expected [200]');
  const body = response.body || {};
  const payload = body.data ? body.data : body;
  client.assert(payload && typeof payload === 'object', 'Expected object payload');
  client.assert(Array.isArray(payload.content), 'Expected payload.content to be an array');
  client.assert(typeof payload.totalElements === 'number', 'Expected payload.totalElements number');
  if (payload.content.length > 0) {
    const first = payload.content[0];
    client.assert(typeof first.id === 'number', 'Expected first item id:number');
    client.assert(typeof first.email === 'string', 'Expected first item email:string');
  }
});
%}

### EDGE_users_invalid_role_filter
# @name EDGE_users_invalid_role_filter
GET {{baseUrl}}/api/users?page=0&size=20&role=__INVALID_ROLE__
Authorization: Bearer {{adminAccessToken}}

> {%
client.test("EDGE_users_invalid_role_filter -> [200] + payload", function () {
  client.assert(response.status === 200, 'Unexpected status ' + response.status + '; expected [200]');
  const body = response.body || {};
  const payload = body.data ? body.data : body;
  client.assert(payload && typeof payload === 'object', 'Expected object payload');
  client.assert(Array.isArray(payload.content), 'Expected payload.content to be an array');
  client.assert(typeof payload.totalElements === 'number', 'Expected payload.totalElements number');
});
%}

