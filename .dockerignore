# Keep Docker build context minimal and prevent leaking secrets/certs into daemon cache
.env
.env.*
.local-certs/
secrets/
.git/
.github/
.cache/
.tmp/
**/target/
target/
!services/analysis-service/target/
!services/analysis-service/target/*.jar
!services/api-gateway/target/
!services/api-gateway/target/*.jar
!services/identity-service/target/
!services/identity-service/target/*.jar
!services/notification-service/target/
!services/notification-service/target/*.jar
!services/project-config-service/target/
!services/project-config-service/target/*.jar
!services/report-service/target/
!services/report-service/target/*.jar
!services/sync-service/target/
!services/sync-service/target/*.jar
!services/user-group-service/target/
!services/user-group-service/target/*.jar
**/*.log
**/*.pem
**/*.key
**/*.crt
**/*.p12
**/*.pfx
**/*.jks
k8s-secrets.template.yml
k8s-deployment-example.yaml
docker-compose*.yml
docs/
CLEANUP_REPORT.md
DEPLOYMENT.md

