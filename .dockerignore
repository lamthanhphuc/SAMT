# Keep Docker build context minimal and prevent leaking secrets/certs into daemon cache
.env
.env.*
.local-certs/
secrets/
.git/
.github/
.cache/
.tmp/
**/target/
target/
!analysis-service/target/
!analysis-service/target/*.jar
!api-gateway/target/
!api-gateway/target/*.jar
!identity-service/target/
!identity-service/target/*.jar
!notification-service/target/
!notification-service/target/*.jar
!project-config-service/target/
!project-config-service/target/*.jar
!report-service/target/
!report-service/target/*.jar
!sync-service/target/
!sync-service/target/*.jar
!user-group-service/target/
!user-group-service/target/*.jar
**/*.log
**/*.pem
**/*.key
**/*.crt
**/*.p12
**/*.pfx
**/*.jks
k8s-secrets.template.yml
k8s-deployment-example.yaml
docker-compose*.yml
docs/
CLEANUP_REPORT.md
DEPLOYMENT.md
