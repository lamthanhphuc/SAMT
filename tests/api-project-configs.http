@baseUrl = http://localhost:9080
@identityBaseUrl = http://localhost:8081
@adminEmail = admin@example.com
@adminPassword = password
@lecturerEmail = lecturer@example.com
@lecturerPassword = password
@studentEmail = student@example.com
@studentPassword = password
@adminAccessToken = invalid.jwt.token
@studentAccessToken = invalid.jwt.token
@adminRefreshToken = invalid.refresh.token
# Optional environment variable usage:
# @baseUrl = {{BASE_URL}}
# @adminEmail = {{ADMIN_EMAIL}}
# @adminPassword = {{ADMIN_PASSWORD}}
@invalidUuid = not-a-uuid
@missingToken = invalid.jwt.token

### Bootstrap admin login
# @name adminLogin
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

> {%
client.test("admin login", function () {
  client.assert(response.status === 200 || response.status === 401);
  if (response.status === 200 && response.body.accessToken) {
    client.global.set("adminAccessToken", response.body.accessToken);
  }
  if (response.status === 200 && response.body.refreshToken) {
    client.global.set("adminRefreshToken", response.body.refreshToken);
  }
});
%}

### Bootstrap student login
# @name studentLogin
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "{{studentEmail}}",
  "password": "{{studentPassword}}"
}

> {%
client.test("student login", function () {
  client.assert(response.status === 200 || response.status === 401);
  if (response.status === 200 && response.body.accessToken) {
    client.global.set("studentAccessToken", response.body.accessToken);
  }
});
%}

