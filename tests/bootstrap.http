### Lecturer login
# @name lecturerLogin
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "{{lecturerEmail}}",
  "password": "{{lecturerPassword}}"
}

> {%
client.test("lecturer login", function () {
  client.assert(response.status === 200);
  client.assert(response.body.accessToken);
  const lecturerPayload = JSON.parse(Buffer.from(response.body.accessToken.split('.')[1], 'base64url').toString('utf8'));
  client.global.set("lecturerAccessToken", response.body.accessToken);
  client.global.set("fixtureLecturerAccessToken", response.body.accessToken);
  client.global.set("fixtureLecturerId", client.global.get("fixtureLecturerId") || lecturerPayload.sub);
});
%}

### Student login
# @name studentLogin
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "{{studentEmail}}",
  "password": "{{studentPassword}}"
}

> {%
client.test("student login", function () {
  client.assert(response.status === 200);
  client.assert(response.body.accessToken);
  const studentPayload = JSON.parse(Buffer.from(response.body.accessToken.split('.')[1], 'base64url').toString('utf8'));
  client.global.set("studentAccessToken", response.body.accessToken);
  client.global.set("studentToken", response.body.accessToken);
  client.global.set("fixtureStudentAccessToken", response.body.accessToken);
  client.global.set("fixtureUserId", studentPayload.sub);
});
%}

