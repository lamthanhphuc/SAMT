Content-Type: application/json

{
  "email": "{{student2Email}}",
  "password": "{{student2Password}}",
  "fullName": "QA Student Two",
  "role": "STUDENT"
}

> {%
client.test("ensure qa student2", function () {
  client.assert(response.status === 201);
  client.assert(response.body?.user?.id);
