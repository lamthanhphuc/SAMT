### Resolve existing lifecycle membership
# @name resolveStatefulLifecycleMembership
GET {{baseUrl}}/api/users/{{fixtureStatefulMemberUserId}}/groups?semesterId={{fixtureSemesterId}}
Authorization: Bearer {{adminAccessToken}}

> {%
client.test("resolve existing lifecycle membership", function () {
  client.assert(response.status === 200);
  const responseData = response.body && response.body.data ? response.body.data : response.body;
  const groups = Array.isArray(responseData)
    ? responseData
    : responseData && Array.isArray(responseData.content)
      ? responseData.content
      : [];
  const existingGroup = groups[0];
  client.global.set('fixtureStatefulExistingGroupId', existingGroup ? (existingGroup.groupId || existingGroup.id) : 999999999);
});
%}

### Cleanup existing lifecycle membership
# @name cleanupStatefulLifecycleMembership
DELETE {{baseUrl}}/api/groups/{{fixtureStatefulExistingGroupId}}/members/{{fixtureStatefulMemberUserId}}
Authorization: Bearer {{adminAccessToken}}

> {%
client.test("cleanup existing lifecycle membership", function () {
  client.assert([204, 404].includes(response.status));
});
%}

