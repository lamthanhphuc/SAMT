@baseUrl = http://localhost:9080
@adminEmail = admin@samt.local
@adminPassword = Str0ng@Pass!
@lecturerEmail = qa.lecturer@samt.local
@studentEmail = qa.student@samt.local
@student2Email = qa.student2@samt.local
@userPassword = Str0ng@Pass!
@semesterCode = QA-2026-S1
@semesterName = QA Semester 2026 S1
@groupName = SE2601-G1
@emptyGroupName = SE2601-G2
@deletableConfigGroupName = SE2601-G3
@jiraHostUrl = https://example.atlassian.net
@jiraApiToken = ATATTAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
@githubRepoUrl = https://github.com/example-org/example-repo
@githubToken = ghp_AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

### Validate fixture users from bootstrap
# @name validateFixtureUsers
GET {{baseUrl}}/actuator/health

> {%
client.test("validate fixture users from bootstrap", function () {
  client.assert(response.status === 200);
  client.assert(!!client.global.get('fixtureLecturerId'), 'fixtureLecturerId missing from bootstrap');
  client.assert(!!client.global.get('fixtureUserId'), 'fixtureUserId missing from bootstrap');
  client.assert(!!client.global.get('fixtureStudent2Id'), 'fixtureStudent2Id missing from bootstrap');
});
%}

### Create fixture semester
# @name createFixtureSemester
POST {{baseUrl}}/api/semesters
Authorization: Bearer {{adminAccessToken}}
Content-Type: application/json

{
  "semesterCode": "{{semesterCode}}",
  "semesterName": "{{semesterName}}",
  "startDate": "2026-06-01",
  "endDate": "2026-08-31"
}

> {%
client.test("create fixture semester", function () {
  client.assert([200, 201, 409].includes(response.status));
  const responseData = response.body && response.body.data ? response.body.data : response.body;
  if (responseData && responseData.id) {
    client.global.set('fixtureSemesterId', responseData.id);
  }
});
%}

### Resolve fixture semester
# @name resolveFixtureSemester
GET {{baseUrl}}/api/semesters?page=0&size=200
Authorization: Bearer {{adminAccessToken}}

> {%
client.test("resolve fixture semester", function () {
  client.assert(response.status === 200);
  const responseData = response.body && response.body.data ? response.body.data : response.body;
  const content = Array.isArray(responseData)
    ? responseData
    : responseData && Array.isArray(responseData.content)
      ? responseData.content
      : [];
  const semester = content.find((item) => item.semesterCode === request.variables.get('semesterCode'));
  client.assert(!!semester, 'QA semester not found');
  client.global.set('fixtureSemesterId', semester.id);
});
%}

### Create fixture group
# @name createFixtureGroup
POST {{baseUrl}}/api/groups
Authorization: Bearer {{adminAccessToken}}
Content-Type: application/json

{
  "groupName": "{{groupName}}",
  "semesterId": {{fixtureSemesterId}},
  "lecturerId": {{fixtureLecturerId}}
}

> {%
client.test("create fixture group", function () {
  client.assert([200, 201, 409].includes(response.status));
  const responseData = response.body && response.body.data ? response.body.data : response.body;
  if (responseData && responseData.id) {
    client.global.set('fixtureGroupId', responseData.id);
  }
});
%}

### Resolve fixture group
# @name resolveFixtureGroup
GET {{baseUrl}}/api/groups?page=0&size=100&semesterId={{fixtureSemesterId}}
Authorization: Bearer {{adminAccessToken}}

> {%
client.test("resolve fixture group", function () {
  client.assert(response.status === 200);
  const responseData = response.body && response.body.data ? response.body.data : response.body;
  const content = Array.isArray(responseData)
    ? responseData
    : responseData && Array.isArray(responseData.content)
      ? responseData.content
      : [];
  const group = content.find((item) => item.groupName === request.variables.get('groupName'));
  client.assert(!!group, 'QA group not found');
  client.global.set('fixtureGroupId', group.id || group.groupId);
});
%}

