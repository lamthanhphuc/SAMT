### Create fixture project config
# @name createFixtureProjectConfig
POST {{baseUrl}}/api/project-configs
Authorization: Bearer {{adminAccessToken}}
Content-Type: application/json

{
  "groupId": {{fixtureGroupId}},
  "jiraHostUrl": "{{jiraHostUrl}}",
  "jiraApiToken": "{{jiraApiToken}}",
  "githubRepoUrl": "{{githubRepoUrl}}",
  "githubToken": "{{githubToken}}"
}

> {%
client.test("create fixture project config", function () {
  client.assert([201, 401, 409].includes(response.status));
  const id = response.body && (response.body.id || (response.body.data && response.body.data.id));
  if (id) {
    client.global.set('fixtureProjectConfigId', id);
  }
});
%}

### Resolve fixture project config
# @name resolveFixtureProjectConfig
GET {{baseUrl}}/api/project-configs/group/{{fixtureGroupId}}
Authorization: Bearer {{adminAccessToken}}

> {%
client.test("resolve fixture project config", function () {
  client.assert(response.status === 200);
  const data = response.body && response.body.data ? response.body.data : response.body;
  client.assert(!!data && !!(data.id || data.configId), 'QA project config not found');
  client.global.set('fixtureProjectConfigId', data.id || data.configId);
});
%}

