### Resolve deletable project config fixture
# @name resolveDeletableProjectConfig
GET {{baseUrl}}/api/project-configs/group/{{fixtureDeletableConfigGroupId}}
Authorization: Bearer {{adminAccessToken}}

> {%
client.test("resolve deletable project config fixture", function () {
  client.assert([200, 404].includes(response.status));
  if (response.status === 200) {
    const data = response.body && response.body.data ? response.body.data : response.body;
    client.assert(!!data && !!(data.id || data.configId), 'Deletable project config fixture not found');
    client.global.set('fixtureDeletableProjectConfigId', data.id || data.configId);
  }
});
%}

### Final fixture sanity check
# @name fixtureSanity
GET {{baseUrl}}/actuator/health

> {%
client.test("fixture vars present", function () {
  client.assert(!!client.global.get('fixtureAdminAccessToken') || !!client.global.get('adminAccessToken'));
  client.assert(!!client.global.get('fixtureLecturerAccessToken') || !!client.global.get('lecturerAccessToken'));
  client.assert(!!client.global.get('fixtureStudentAccessToken') || !!client.global.get('studentAccessToken'));
  client.assert(!!client.global.get('fixtureAdminLifecycleUserId'));
  client.assert(!!client.global.get('fixtureStatefulMemberUserId'));
  client.assert(!!client.global.get('fixtureSemesterId'));
  client.assert(!!client.global.get('fixtureGroupId'));
  client.assert(!!client.global.get('fixtureEmptyGroupId'));
  client.assert(!!client.global.get('fixtureDeletableConfigGroupId'));
  client.assert(!!client.global.get('fixtureProjectConfigId'));
  client.assert(!!client.global.get('fixtureDeletableProjectConfigId'));
});
%}
