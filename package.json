{
  "name": "samt-api-qa",
  "version": "1.0.0",
  "private": true,
  "description": "API testing and OpenAPI automation for SAMT",
  "scripts": {
    "test:smoke": "httpyac tests/api-smoke.http --all",
    "test:regression": "httpyac tests --all",
    "openapi:generate": "node scripts/generate-openapi.mjs",
    "tests:generate": "node scripts/generate-httpyac-tests.mjs",
    "postman:generate": "openapi2postmanv2 -s openapi.yaml -o postman-collection.json -p",
    "contract:schemathesis": "schemathesis run openapi.yaml --url=$BASE_URL",
    "contract:schemathesis:docker": "node scripts/run-schemathesis-docker.mjs"
  },
  "devDependencies": {
    "dotenv": "^16.6.1",
    "httpyac": "^6.16.4",
    "js-yaml": "^4.1.0",
    "openapi-to-postmanv2": "^5.3.0"
  }
}
