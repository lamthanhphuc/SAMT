{
  "schemas": {
    "identity_JwksKey": {
      "type": "object",
      "properties": {
        "kty": {
          "type": "string"
        },
        "use": {
          "type": "string"
        },
        "alg": {
          "type": "string"
        },
        "kid": {
          "type": "string"
        },
        "n": {
          "type": "string"
        },
        "e": {
          "type": "string"
        },
        "key_ops": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "identity_JwksResponse": {
      "type": "object",
      "properties": {
        "keys": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/identity_JwksKey"
          }
        }
      }
    },
    "identity_UserDto": {
      "properties": {
        "jiraAccountId": {
          "nullable": true
        },
        "githubUsername": {
          "nullable": true
        }
      }
    },
    "identity_AuditLog": {
      "properties": {
        "actorId": {
          "nullable": true
        },
        "actorEmail": {
          "nullable": true
        },
        "timestamp": {
          "type": "string",
          "format": null
        },
        "ipAddress": {
          "nullable": true
        },
        "userAgent": {
          "nullable": true
        },
        "oldValue": {
          "nullable": true
        },
        "newValue": {
          "nullable": true
        }
      }
    },
    "identity_JsonNode": {
      "nullable": true
    },
    "userGroup_MemberInfo": {
      "properties": {
        "email": {
          "nullable": true
        }
      }
    },
    "projectConfig_ConfigData": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "groupId": {
          "type": "integer",
          "format": "int64"
        },
        "jiraHostUrl": {
          "type": "string"
        },
        "jiraEmail": {
          "type": "string",
          "format": "email"
        },
        "jiraApiToken": {
          "type": "string"
        },
        "githubRepoUrl": {
          "type": "string"
        },
        "githubToken": {
          "type": "string"
        },
        "state": {
          "type": "string"
        },
        "lastVerifiedAt": {
          "type": "string",
          "format": "date-time",
          "nullable": true
        },
        "invalidReason": {
          "type": "string",
          "nullable": true
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "projectConfig_ConfigEnvelope": {
      "type": "object",
      "properties": {
        "data": {
          "$ref": "#/components/schemas/projectConfig_ConfigData"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "projectConfig_VerificationEnvelope": {
      "type": "object",
      "properties": {
        "data": {
          "type": "object",
          "additionalProperties": true
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  },
  "operations": {
    "get /.well-known/jwks.json": {
      "responses": {
        "200": {
          "description": "OK",
          "contentType": "application/json",
          "contentSchemaRef": "#/components/schemas/identity_JwksResponse"
        }
      }
    },
    "get /api/project-configs/group/{groupId}": {
      "responses": {
