# ==============================================
# SAMT - LOCAL DEVELOPMENT ENVIRONMENT
# ==============================================
# File này dành cho local development (chạy từ IDE)
# Copy thành .env.local và set trong IntelliJ/Eclipse

# Database (Docker containers)
SPRING_DATASOURCE_USERNAME=postgres
# ⚠️ Replace with a strong local-only password. Do not reuse in staging/prod.
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# Redis
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

# Logging (keep safe-by-default; opt into verbosity when troubleshooting)
LOG_LEVEL=INFO
SHOW_SQL=false
SQL_LOG_LEVEL=INFO

# JPA
DDL_AUTO=update

# Optional: OWASP Dependency-Check (local security scan only)
NVD_API_KEY=
